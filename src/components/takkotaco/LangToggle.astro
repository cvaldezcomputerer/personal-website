---
/**
 * LangToggle (live) - a miniature of the bilingual system that runs all of
 * takkotaco.com. On the real site every visible string is wrapped in one <T>
 * component with an `en` slot and a `ja` slot, and a single switch flips the
 * whole page between them. This is that mechanism in one card: the same paired
 * strings, the same in-place swap. Without JS the English shows and nothing
 * breaks.
 */
---

<figure class="lang-demo" data-lang="en">
  <div class="lang-demo__bar" role="group" aria-label="Display language">
    <button class="lang-demo__btn is-active" type="button" data-set="en" aria-pressed="true">EN</button>
    <button class="lang-demo__btn" type="button" data-set="ja" lang="ja" aria-pressed="false">日本語</button>
  </div>

  <div class="lang-demo__card">
    <p class="lang-demo__eyebrow">
      <span class="t t-en">Counting game</span>
      <span class="t t-ja" lang="ja" hidden>かぞえゲーム</span>
    </p>
    <h5 class="lang-demo__title">
      <span class="t t-en">How Many?</span>
      <span class="t t-ja" lang="ja" hidden>かぞえよう</span>
    </h5>
    <p class="lang-demo__desc">
      <span class="t t-en">Watch the objects fly by, then count how many.</span>
      <span class="t t-ja" lang="ja" hidden>とんでいくものをよくみて、いくつあるかかぞえよう。</span>
    </p>
  </div>

  <figcaption>Live: one component wraps every string; the real site flips on this switch.</figcaption>
</figure>

<script>
  document.querySelectorAll<HTMLElement>('.lang-demo').forEach((demo) => {
    const btns = demo.querySelectorAll<HTMLButtonElement>('.lang-demo__btn');
    const apply = (lang: string) => {
      demo.dataset.lang = lang;
      demo.querySelectorAll<HTMLElement>('.t-en').forEach((el) => (el.hidden = lang !== 'en'));
      demo.querySelectorAll<HTMLElement>('.t-ja').forEach((el) => (el.hidden = lang !== 'ja'));
      btns.forEach((b) => {
        const on = b.dataset.set === lang;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    };
    btns.forEach((b) => b.addEventListener('click', () => apply(b.dataset.set || 'en')));
  });
</script>

<style>
  .lang-demo {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .lang-demo [hidden] { display: none; }

  .lang-demo__bar {
    display: inline-flex;
    align-self: flex-start;
    gap: 2px;
    padding: 3px;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
  }
  .lang-demo__btn {
    appearance: none;
    border: 0;
    cursor: pointer;
    font: inherit;
    font-size: var(--text-xs);
    font-weight: 600;
    line-height: 1;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    color: var(--color-text-muted);
    background: transparent;
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }
  .lang-demo__btn.is-active {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
  }

  .lang-demo__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }
  .lang-demo__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin: 0 0 var(--space-2);
  }
  .lang-demo__title {
    font-size: var(--text-lg);
    color: var(--color-text);
    margin: 0 0 var(--space-1);
  }
  .lang-demo__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  figcaption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
