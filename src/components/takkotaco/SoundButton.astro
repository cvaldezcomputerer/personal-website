---
/**
 * SoundButton (live) - a stand-in for the games' procedural sound layer. On the
 * real site a sound resolves in tiers: a recorded Kenney clip first, then an
 * ElevenLabs voice, and if neither exists the game synthesizes the tone itself
 * with the Web Audio API. That last tier is what runs here: these blips are
 * generated in the browser on click, from no audio files at all. The bars are
 * decorative feedback, not a real analyser.
 */
---

<figure class="sfx-demo">
  <div class="sfx-demo__stage">
    <div class="sfx-demo__bars" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="sfx-demo__btns">
      <button type="button" class="sfx-btn" data-sound="correct">Correct</button>
      <button type="button" class="sfx-btn" data-sound="blip">Blip</button>
    </div>
  </div>
  <figcaption>Live: generated in the browser with the Web Audio API, no sound files.</figcaption>
</figure>

<script>
  const AC = window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let ctx: AudioContext | null = null;

  function tone(freq: number, start: number, dur: number, type: OscillatorType, peak: number) {
    if (!ctx) return;
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = type;
    osc.frequency.value = freq;
    // Short attack, exponential release, so notes have no click at the edges.
    gain.gain.setValueAtTime(0.0001, start);
    gain.gain.exponentialRampToValueAtTime(peak, start + 0.012);
    gain.gain.exponentialRampToValueAtTime(0.0001, start + dur);
    osc.connect(gain).connect(ctx.destination);
    osc.start(start);
    osc.stop(start + dur + 0.02);
  }

  // Each returns roughly how long it sounds, in ms, to time the bar animation.
  const sounds: Record<string, () => number> = {
    correct() {
      const t = ctx!.currentTime;
      [523.25, 659.25, 783.99].forEach((f, i) => tone(f, t + i * 0.1, 0.16, 'sine', 0.22));
      return 420;
    },
    blip() {
      tone(660, ctx!.currentTime, 0.12, 'triangle', 0.28);
      return 160;
    },
  };

  document.querySelectorAll<HTMLElement>('.sfx-demo').forEach((demo) => {
    let off = 0;
    demo.querySelectorAll<HTMLButtonElement>('.sfx-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (!ctx) ctx = new AC();
        if (ctx.state === 'suspended') void ctx.resume();
        const play = sounds[btn.dataset.sound || 'blip'];
        const ms = play ? play() : 160;
        if (reduce) return;
        window.clearTimeout(off);
        demo.classList.add('is-playing');
        off = window.setTimeout(() => demo.classList.remove('is-playing'), ms);
      });
    });
  });
</script>

<style>
  .sfx-demo {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sfx-demo__stage {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .sfx-demo__bars {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 34px;
  }
  .sfx-demo__bars span {
    width: 5px;
    height: 30%;
    background: var(--color-accent);
    border-radius: var(--radius-xs);
  }
  .sfx-demo.is-playing .sfx-demo__bars span {
    animation: sfx-bar 0.5s ease-in-out infinite;
  }
  .sfx-demo__bars span:nth-child(2) { animation-delay: 0.08s; }
  .sfx-demo__bars span:nth-child(3) { animation-delay: 0.16s; }
  .sfx-demo__bars span:nth-child(4) { animation-delay: 0.24s; }
  .sfx-demo__bars span:nth-child(5) { animation-delay: 0.32s; }
  @keyframes sfx-bar {
    0%, 100% { height: 25%; }
    50% { height: 95%; }
  }

  .sfx-demo__btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .sfx-btn {
    appearance: none;
    cursor: pointer;
    font: inherit;
    font-weight: 600;
    font-size: var(--text-sm);
    padding: 0.45rem 0.9rem;
    color: var(--color-text);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }
  .sfx-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-strong);
  }

  figcaption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .sfx-demo.is-playing .sfx-demo__bars span { animation: none; }
  }
</style>
