---
/**
 * Footer - copyright + the real social links (GitHub, LinkedIn, email). Kept
 * minimal and contained, in keeping with the restrained chrome.
 */
import Icon, { type IconName } from '~/components/Icon.astro';

const year = new Date().getFullYear();
const socials: { href: string; label: string; icon: IconName }[] = [
  { href: 'https://github.com/cvaldezcomputerer', label: 'GitHub', icon: 'github' },
  { href: 'https://www.linkedin.com/in/cristian-valdez-203136378', label: 'LinkedIn', icon: 'linkedin' },
  { href: 'mailto:cvaldezana@gmail.com', label: 'Email', icon: 'mail' },
];
---

<footer class="site-footer">
  <div class="container inner">
    <p class="copy">&copy; {year} Cristian Valdez</p>
    <ul class="socials" role="list">
      {
        socials.map((s) => (
          <li>
            <a href={s.href} aria-label={s.label} rel="me noopener" target="_blank">
              <Icon name={s.icon} />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-9);
    padding-block: var(--space-6);
  }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .copy {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .socials {
    display: flex;
    gap: var(--space-2);
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    font-size: 1.15rem;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast) ease, background-color var(--transition-fast) ease;
  }
  .socials a:hover {
    color: var(--color-text);
    background: var(--color-surface-2);
  }
</style>
