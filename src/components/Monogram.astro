<style>
  .monogram {
    display: inline-flex;
    width: 2.75rem;
    height: 2.75rem;
    flex: none;
    color: var(--color-accent);
    transition: color var(--transition-fast) ease, transform var(--transition-fast) var(--ease-out);
  }
  .monogram:hover {
    color: var(--color-accent-strong);
    transform: translateY(-1px);
  }
  .monogram svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
