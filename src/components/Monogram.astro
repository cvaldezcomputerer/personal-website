---
/**
 * Monogram - the クリス (Kurisu) name-seal, our hanko brand mark. A sage stamp:
 * a thin ring with クリス stacked vertically. The kana are Noto Sans JP
 * 900 converted to outline paths, so the mark needs no webfont and renders
 * identically everywhere. Its romaji sibling, a CV seal, is the favicon
 * (public/favicon.svg) - CV reads at 16px where the kana muddies. Used as the
 * home link in the homepage sidebar and the inner-page Nav.
 */
interface Props {
  href?: string;
  label?: string;
  class?: string;
}
const { href = '/', label = 'Cristian Valdez - home', class: className } = Astro.props;
