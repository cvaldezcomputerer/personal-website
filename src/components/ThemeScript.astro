---
/**
 * Sets the color theme on <html> BEFORE first paint, so there is no flash of
 * the wrong theme. Honors the saved choice (localStorage 'theme'), else the OS
 * `prefers-color-scheme`. The nav toggle updates both localStorage and the
 * data-theme attribute live. Keep this in <head>, above the stylesheet.
 */
---
<script is:inline>
  (function () {
    try {
      var saved = localStorage.getItem('theme');
      var theme =
        saved === 'light' || saved === 'dark'
          ? saved
          : window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
      document.documentElement.dataset.theme = theme;
    } catch (e) {
      document.documentElement.dataset.theme = 'light';
    }
  })();
</script>
