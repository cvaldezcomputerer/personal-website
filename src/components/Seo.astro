---
/**
 * Seo - canonical + Open Graph + Twitter + optional JSON-LD. Rendered inside
 * <head> by BaseLayout, so every page inherits it. Needs `site` set in
 * astro.config (it is). Pass `image` (path or absolute) for share cards once OG
 * images exist; omitted for now means no image tags rather than a broken URL.
 */
interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  jsonLd?: object;
}

const { title, description, image, noindex = false, type = 'website', jsonLd } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;
const siteName = 'Cristian Valdez';
---

<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{jsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}
