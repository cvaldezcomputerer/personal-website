---
/**
 * PressToLight - the momentary-pushbutton toy from bloggydoggy.com's
 * culture-festival post, ported for the case study. Pressing the flat tactile
 * switch swaps the photo between LED-off and LED-on and replays the little
 * squish-and-bounce on the cap. Same markup, script, and button styling as
 * the source; the blog's OptimizedImage is swapped for astro:assets Image,
 * and the two frames (this component's only ever use) are baked in rather
 * than passed as props.
 *
 * The button greys (#c2c2c7 body, #1c1c1c cap) are the component itself, a
 * drawing of a real electronics part, not site chrome, so they stay literal
 * instead of tokenized, same as on the blog.
 */
import { Image } from 'astro:assets';
import buttonBefore from '~/assets/images/bloggydoggy/button-before.jpg';
import buttonLit from '~/assets/images/bloggydoggy/button-lit.jpg';
---

<figure class="ptl">
  <div class="ptl-stage">
    <span class="ptl-img ptl-off">
      <Image src={buttonBefore} alt="A breadboard circuit with the LED off" width={480} />
    </span>
    <span class="ptl-img ptl-on" aria-hidden="true">
      <Image src={buttonLit} alt="" width={480} />
    </span>
  </div>

  <button type="button" class="ptl-btn" aria-label="Press the button to light up the LED">
    <span class="ptl-btn-cap"></span>
  </button>
</figure>

<script>
  // Each press switches the photo between LED-off and LED-on, and replays the
  // little squish-and-bounce on the black cap. Delegated on document, same as
  // the source.
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const btn = target.closest('.ptl-btn');
    if (!btn) return;
    const root = btn.closest('.ptl');
    if (!root) return;
    root.classList.toggle('lit');
    const cap = btn.querySelector('.ptl-btn-cap');
    if (!cap) return;
    cap.classList.remove('is-pressing');
    void (cap as HTMLElement).offsetWidth;
    cap.classList.add('is-pressing');
  });
</script>

<style>
  .ptl {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .ptl-stage {
    position: relative;
    width: 100%;
    max-width: 480px;
  }

  .ptl-off :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
  }

  /* The lit frame sits exactly over the off frame and appears instantly */
  .ptl-on {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  .ptl-on :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-sm);
  }
  .ptl.lit .ptl-on { opacity: 1; }

  /* ---- The electronics pushbutton (flat tactile switch) ---- */
  .ptl-btn {
    position: relative;
    width: 64px;
    height: 64px;
    padding: 0;
    border: 1px solid #8a8a90;
    border-radius: 10px;
    background: #c2c2c7;
    box-shadow: 0 5px 0 #8f8f95;
    display: grid;
    place-items: center;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  /* Two metal legs poking out the sides, so it reads as a real component */
  .ptl-btn::before,
  .ptl-btn::after {
    content: '';
    position: absolute;
    top: 19px;
    bottom: 19px;
    width: 8px;
    background: #b0b0b5;
    border-radius: 2px;
    z-index: -1;
  }
  .ptl-btn::before { left: -6px; }
  .ptl-btn::after { right: -6px; }

  .ptl-btn-cap {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1c1c1c;
  }

  .ptl-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  /* Press: squish down a touch, then spring back a little past full size.
     Momentary - the button never latches in a pressed state. */
  @keyframes ptl-press {
    0%   { transform: scale(1); }
    35%  { transform: scale(0.9); }
    70%  { transform: scale(1.06); }
    100% { transform: scale(1); }
  }
  .ptl-btn-cap.is-pressing {
    animation: ptl-press 0.32s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .ptl-btn-cap.is-pressing { animation: none; }
  }
</style>
