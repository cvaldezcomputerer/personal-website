---
/**
 * QuizDemo - the quiz web component from bloggydoggy.com, ported for the case
 * study. Same custom-element mechanics as the blog's Quiz.astro (vote once,
 * bars animate in, correct/wrong revealed), but wired to sample vote counts
 * instead of the live Workers + D1 API, and votes are kept in memory so a
 * reload resets the demo. The question is a real one from the blog's
 * culture-festival post.
 *
 * Trilingual: every string carries its three modes, toggled by the
 * `bd-demo:lang` event that LangDemo broadcasts, mirroring how the blog's
 * navbar toggle reaches every quiz on a page. The scrapbook styling (tape
 * corners, paper-strip options, slight tilt) is the blog's own look, remapped
 * to this site's tokens.
 */
interface Tri {
  en: string;
  ja?: string;
  en_simple?: string;
}

const question: Tri = {
  en: 'Can you guess my favorite One Piece character?',
  ja: '私の好きなワンピースのキャラクターを当てられますか？',
  en_simple: 'Who is my favorite One Piece character?',
};

const options: Tri[] = [
  { en: 'Zoro', ja: 'ゾロ' },
  { en: 'Luffy', ja: 'ルフィ' },
  { en: 'Chopper', ja: 'チョッパー' },
  { en: 'Sanji', ja: 'サンジ' },
];

const correctIndex = 0;
// Sample counts standing in for the live D1 tallies.
const seedVotes = [46, 38, 27, 12];
---

<bd-quiz-demo data-correct-index={correctIndex} data-seed={seedVotes.join(',')}>
  <div class="quiz-card">
    <div class="tape tape-tl"></div>
    <div class="tape tape-tr"></div>
    <div class="tape tape-bl"></div>
    <div class="tape tape-br"></div>

    <h3 class="quiz-question">
      <span class="tri">
        <span data-tri="en" lang="en">{question.en}</span>
        <span data-tri="ja" lang="ja" class="is-hidden">{question.ja ?? question.en}</span>
        <span data-tri="en_simple" lang="en" class="is-hidden">{question.en_simple ?? question.en}</span>
      </span>
    </h3>

    <div class="quiz-options">
      {
        options.map((option, index) => (
          <button class="quiz-option" data-index={index} type="button">
            <span class="option-label">
              <span class="tri">
                <span data-tri="en" lang="en">{option.en}</span>
                <span data-tri="ja" lang="ja" class="is-hidden">{option.ja ?? option.en}</span>
                <span data-tri="en_simple" lang="en" class="is-hidden">{option.en_simple ?? option.en}</span>
              </span>
            </span>
            <span class="option-percentage"></span>
            <div class="progress-bar"></div>
          </button>
        ))
      }
    </div>

    <div class="quiz-footer">
      <span class="total-votes"></span>
    </div>
  </div>
</bd-quiz-demo>

<script>
  // The blog's QuizComponent, minus the network: votes come from data-seed and
  // live in memory, so reloading the page resets the demo.
  class BdQuizDemo extends HTMLElement {
    private buttons!: NodeListOf<HTMLButtonElement>;
    private meta!: HTMLElement | null;
    private hasVoted = false;
    private votes: number[] = [];
    private correctIndex = -1;

    connectedCallback() {
      this.buttons = this.querySelectorAll('.quiz-option');
      this.meta = this.querySelector('.total-votes');
      this.correctIndex = parseInt(this.dataset.correctIndex ?? '-1');
      this.votes = (this.dataset.seed ?? '').split(',').map((n) => parseInt(n) || 0);

      this.updateUI();
      this.buttons.forEach((btn) => {
        btn.addEventListener('click', () => this.handleVote(btn));
      });

      document.addEventListener('bd-demo:lang', ((e: CustomEvent<{ lang: string }>) => {
        this.querySelectorAll<HTMLElement>('[data-tri]').forEach((el) => {
          el.classList.toggle('is-hidden', el.dataset.tri !== e.detail.lang);
        });
      }) as EventListener);
    }

    handleVote(btn: HTMLButtonElement) {
      if (this.hasVoted) return;
      this.hasVoted = true;

      const index = parseInt(btn.dataset.index ?? '0');
      this.votes[index] += 1;
      btn.classList.add('selected');

      this.buttons.forEach((b) => {
        b.disabled = true;
        b.classList.add('show-results');
        const i = parseInt(b.dataset.index ?? '-1');
        if (i === this.correctIndex) b.classList.add('correct');
        else if (b.classList.contains('selected')) b.classList.add('wrong');
      });

      this.updateUI();
    }

    updateUI() {
      const total = this.votes.reduce((a, b) => a + b, 0);
      if (this.meta) {
        this.meta.textContent = this.hasVoted
          ? `${total} votes (sample data)`
          : 'demo: sample data, not the live API';
      }
      this.buttons.forEach((b) => {
        const i = parseInt(b.dataset.index ?? '0');
        const percent = total === 0 ? 0 : Math.round((this.votes[i] / total) * 100);
        const bar = b.querySelector<HTMLElement>('.progress-bar');
        if (bar) bar.style.width = this.hasVoted ? `${percent}%` : '0%';
        const text = b.querySelector('.option-percentage');
        if (text) text.textContent = this.hasVoted ? `${percent}%` : '';
      });
    }
  }

  if (!customElements.get('bd-quiz-demo')) {
    customElements.define('bd-quiz-demo', BdQuizDemo);
  }
</script>

<style>
  bd-quiz-demo { display: block; overflow-x: hidden; }

  /* Trilingual stacking, same trick as the blog's T component. */
  .tri { display: inline-grid; align-items: center; }
  .tri > [data-tri] {
    grid-row: 1;
    grid-column: 1;
    transition: opacity 0.15s ease-out;
  }
  .tri > [data-tri].is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .quiz-card {
    position: relative;
    background: var(--color-surface);
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 20px 20px;
    color: var(--color-text);
    padding: var(--space-6);
    margin-inline: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: 5px 5px 0 var(--color-surface-2);
    transform: rotate(-1deg);
  }

  .tape {
    position: absolute;
    width: 90px;
    height: 26px;
    background: var(--color-accent-soft);
    opacity: 0.9;
    z-index: 10;
    border-left: 1px dashed var(--color-border-strong);
    border-right: 1px dashed var(--color-border-strong);
  }
  .tape-tl { top: -9px; left: -26px; transform: rotate(-45deg); }
  .tape-tr { top: -9px; right: -26px; transform: rotate(45deg); }
  .tape-bl { bottom: -9px; left: -26px; transform: rotate(45deg); }
  .tape-br { bottom: -9px; right: -26px; transform: rotate(-45deg); }

  .quiz-question {
    margin: 0 0 var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 700;
    text-align: center;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .quiz-option {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.65rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: 0; /* paper strips */
    cursor: pointer;
    font-family: inherit;
    font-size: var(--text-sm);
    color: var(--color-text);
    overflow: hidden;
    z-index: 1;
    box-shadow: 3px 3px 0 var(--color-surface-2);
    transition: transform 0.1s, box-shadow 0.1s;
  }
  .quiz-option:not(:disabled):hover {
    transform: translate(-1px, -1px);
    box-shadow: 4px 4px 0 var(--color-surface-2);
  }
  .quiz-option:active:not(:disabled) {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 var(--color-surface-2);
  }
  .quiz-option:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .quiz-option:disabled { cursor: default; }

  .quiz-option.selected {
    border-color: var(--color-accent);
    border-width: 2px;
    font-weight: 600;
  }
  .quiz-option.correct {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }
  .quiz-option.correct .option-percentage { color: var(--color-accent-strong); }
  .quiz-option.wrong {
    border-color: var(--color-border-strong);
    color: var(--color-text-muted);
  }

  .progress-bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: var(--color-accent);
    opacity: 0.15;
    width: 0%;
    z-index: -1;
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .option-label { z-index: 2; }
  .option-percentage {
    z-index: 2;
    font-weight: 700;
    color: var(--color-accent);
  }

  .quiz-footer {
    margin-top: var(--space-5);
    padding-top: var(--space-2);
    border-top: 1px dashed var(--color-border-strong);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: flex;
    justify-content: flex-end;
    min-height: 1.4rem;
  }
</style>
