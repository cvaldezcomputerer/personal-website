---
/**
 * LanguageToggle - a small segmented EN / 日本語 control. Each segment is a real
 * link to the same page in the other locale (no client JS), so it works without
 * scripting and is crawlable. The active locale is marked aria-current.
 */
import type { Lang } from '~/i18n/ui';
import { LANG_LABEL } from '~/i18n/ui';

interface Props {
  lang: Lang;
  enHref: string;
  jaHref: string;
  label?: string;
}
const { lang, enHref, jaHref, label = 'Switch language' } = Astro.props;
const options: { code: Lang; href: string }[] = [
  { code: 'en', href: enHref },
  { code: 'ja', href: jaHref },
];
---

<div class="lang no-print" role="group" aria-label={label}>
  {
    options.map((o) => (
      <a
        href={o.href}
        class:list={['lang-opt', { 'is-active': o.code === lang }]}
        aria-current={o.code === lang ? 'true' : undefined}
        lang={o.code}
        hreflang={o.code}
      >
        {o.code === 'en' ? 'EN' : LANG_LABEL.ja}
      </a>
    ))
  }
</div>

<style>
  .lang {
    display: inline-flex;
    padding: 2px;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }
  .lang-opt {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.6rem;
    font-size: var(--text-xs);
    font-weight: 600;
    line-height: 1;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: var(--radius-xs);
    transition: color var(--transition-fast) ease, background-color var(--transition-fast) ease;
  }
  .lang-opt:hover {
    color: var(--color-text);
  }
  .lang-opt.is-active {
    color: var(--color-accent-contrast);
    background: var(--color-accent);
  }
</style>
