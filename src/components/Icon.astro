---
/**
 * Inline-SVG icon. Stroke icons are Lucide (ISC); brand marks are single-path
 * (GitHub from Simple Icons; LinkedIn is the standard mark). No icon webfont or
 * CDN. Sized by font-size - the svg tracks a 1em square. Decorative by default
 * (aria-hidden); pass `label` to expose it to assistive tech.
 */
export type IconName =
  | 'github'
  | 'linkedin'
  | 'mail'
  | 'map-pin'
  | 'arrow-up-right'
  | 'external-link'
  | 'sun'
  | 'moon'
  | 'download'
  | 'rss'
  | 'languages'
  | 'garlic';

interface Props {
  name: IconName;
  class?: string;
  label?: string;
}

const { name, class: className, label } = Astro.props;

// `fill: true` = solid brand glyph; otherwise a Lucide stroke icon. Icons drawn
// in their own coordinate space (not Lucide's 24x24) set `viewBox` + `stroke`.
const ICONS: Record<
  IconName,
  { body: string; fill?: boolean; viewBox?: string; stroke?: number }
> = {
  github: {
    fill: true,
    body: '<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>',
  },
  linkedin: {
    fill: true,
    body: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>',
  },
  mail: {
    body: '<path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/><rect x="2" y="4" width="20" height="16" rx="2"/>',
  },
  'map-pin': {
    body: '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>',
  },
  'arrow-up-right': {
    body: '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>',
  },
  'external-link': {
    body: '<path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>',
  },
  sun: {
    body: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>',
  },
  moon: {
    body: '<path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/>',
  },
  download: {
    body: '<path d="M12 15V3"/><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="m7 10 5 5 5-5"/>',
  },
  rss: {
    body: '<path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>',
  },
  languages: {
    body: '<path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/>',
  },
  // Garlic bulb - the mark from takkotaco.com's homepage background pattern
  // (Takko is Japan's garlic town). Drawn in its own coordinate space.
  garlic: {
    viewBox: '120 140 780 750',
    stroke: 62,
    body: '<path d="M199 468C136.885 532.312 124 583 143 680C191.5 772 243 783 346 792C399.466 819.505 433 839 502 839C579 836 598.935 822.763 652.5 792C784.385 779.941 838 749 863 648.5C866 571.5 847.902 515.187 795.5 461.5C731.75 408.424 693.486 383.276 620 348C597.464 341.182 586.176 332.053 567 312C543.23 277.333 522.5 204.5 531 147L465.5 191C465.5 227.5 455.5 265.5 439.5 301C421.494 325.085 408.38 336.495 378 352C296.829 383.891 257.592 409.289 199 468Z"/>',
  },
};

const icon = ICONS[name];
const a11y = label
  ? ({ role: 'img', 'aria-label': label } as const)
  : ({ 'aria-hidden': 'true' } as const);
---

{
  icon.fill ? (
    <svg class={className} viewBox="0 0 24 24" fill="currentColor" focusable="false" {...a11y} set:html={icon.body} />
  ) : (
    <svg
      class={className}
      viewBox={icon.viewBox ?? '0 0 24 24'}
      fill="none"
      stroke="currentColor"
      stroke-width={icon.stroke ?? 2}
      stroke-linecap="round"
      stroke-linejoin="round"
      focusable="false"
      {...a11y}
      set:html={icon.body}
    />
  )
}

<style>
  svg {
    width: 1em;
    height: 1em;
    display: inline-block;
    vertical-align: -0.125em;
    flex: none;
  }
</style>
