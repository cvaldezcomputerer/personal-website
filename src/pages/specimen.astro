---
/**
 * /specimen - living style guide. Not indexed (in NOINDEX_ROUTES). Use it to
 * eyeball the type scale, palette, and components in both themes. Delete or
 * keep as an internal reference; it never ships to search.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';

const swatches = [
  ['--color-bg', 'bg'],
  ['--color-surface', 'surface'],
  ['--color-surface-2', 'surface-2'],
  ['--color-text', 'text'],
  ['--color-text-muted', 'text-muted'],
  ['--color-text-faint', 'text-faint'],
  ['--color-border', 'border'],
  ['--color-border-strong', 'border-strong'],
  ['--color-accent', 'accent'],
  ['--color-accent-strong', 'accent-strong'],
  ['--color-accent-soft', 'accent-soft'],
  ['--color-accent-contrast', 'accent-contrast'],
];
---

<BaseLayout title="Specimen - Cristian Valdez" noindex>
  <div class="container--page wrap">
    <header class="head">
      <div>
        <p class="eyebrow">Living style guide</p>
        <h1>Specimen</h1>
        <p class="lede">
          Bricolage Grotesque, Hanken Grotesk, and IBM Plex Mono on the
          warm-modern sage palette. Flip the theme to check both.
        </p>
      </div>
      <button id="theme-toggle" class="btn btn--secondary btn--sm" type="button">
        Toggle theme
      </button>
    </header>

    <section>
      <h2>Type</h2>
      <div class="stack">
        <h1>Heading one in Bricolage Grotesque</h1>
        <h2>Heading two in Bricolage Grotesque</h2>
        <h3>Heading three in Bricolage Grotesque</h3>
        <h4>Heading four in Bricolage Grotesque</h4>
        <p>
          Body text in Hanken Grotesk. American IT professional based in Japan,
          building cloud infrastructure and shipping real things on the edge.
          Here is an inline <code>const x = 42</code> in IBM Plex Mono, and a
          <a href="#">sage-green link</a> for good measure.
        </p>
        <p class="muted">Muted text for captions and secondary detail.</p>
        <p class="faint">Faint text for hints and the quietest labels.</p>
        <pre><code>{`// IBM Plex Mono in a code block
export const env = import('cloudflare:workers');`}</code></pre>
      </div>
    </section>

    <section>
      <h2>Color</h2>
      <div class="swatches">
        {swatches.map(([token, label]) => (
          <div class="swatch">
            <div class="chip" style={`background: var(${token})`}></div>
            <div class="swatch-label">
              <span>{label}</span>
              <code>{token}</code>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>Buttons</h2>
      <div class="row">
        <a class="btn btn--primary" href="#">Primary</a>
        <a class="btn btn--secondary" href="#">Secondary</a>
        <a class="btn btn--ghost" href="#">Ghost</a>
        <a class="btn btn--primary btn--sm" href="#">Small</a>
        <a class="btn btn--primary btn--lg" href="#">Large</a>
      </div>
    </section>

    <section>
      <h2>Surface</h2>
      <article class="card">
        <h3>Contained surface</h3>
        <p class="muted">
          A defined panel with its own background, border, and radius. Nothing
          floats in open space - this is the repeated layout primitive.
        </p>
        <div class="row">
          <a class="btn btn--secondary btn--sm" href="#">Action</a>
        </div>
      </article>
    </section>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var root = document.documentElement;
        var next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        try { localStorage.setItem('theme', next); } catch (e) {}
      });
    })();
  </script>
</BaseLayout>

<style>
  .wrap { padding-block: var(--space-8); }
  .wrap > section { margin-top: var(--space-8); }
  .wrap > section > h2 {
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-5);
  }

  .head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }
  .lede {
    max-width: 46ch;
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }

  .stack > * + * { margin-top: var(--space-4); }
  .muted { color: var(--color-text-muted); }
  .faint { color: var(--color-text-faint); }

  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--space-4);
  }
  .swatch {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
  }
  .chip { height: 64px; border-bottom: 1px solid var(--color-border); }
  .swatch-label {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-3);
    font-size: var(--text-sm);
  }
  .swatch-label code { font-size: var(--text-xs); color: var(--color-text-faint); }

  .row { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: center; }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
    max-width: 32rem;
  }
  .card > * + * { margin-top: var(--space-3); }
</style>
